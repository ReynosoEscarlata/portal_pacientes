# Fuente de datos: mock | postgres
DATA_SOURCE=mock

PORT=4000
CORS_ORIGIN=http://localhost:5173

# Clave AES-256 para cifrado en reposo de datos sensibles (64 caracteres hex).
# Genera una propia con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si se deja vacía, en desarrollo se usa una clave derivada NO apta para producción.
ENCRYPTION_KEY=

# Sembrar 3 pacientes ficticios al arrancar (solo aplica con DATA_SOURCE=mock)
SEED_MOCK=true

# PostgreSQL (solo si DATA_SOURCE=postgres)
PGHOST=localhost
PGPORT=5432
PGDATABASE=clinicconnect
PGUSER=postgres
PGPASSWORD=

# Montar el endpoint legacy de práctica en POST /api/legacy/registro
LEGACY_ENABLED=false
